rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: staff
    // Fields: name (string), role (string), monthlySalary (number), active (boolean)
    //
    // Collection: attendance
    // Fields: date (string), staffId (string), status (string: present/absent/half-day/holiday)
    //
    // Collection: sales
    // Fields: date (string), salesmanId (string, optional), customerName (string), product (string), quantity (number), amount (number), paymentStatus (string: paid/pending)
    //
    // Collection: expenses
    // Fields: date (string), type (string: advance/transport/other), amount (number), staffId (string, optional), description (string)
    //
    // Collection: users
    // Fields: email (string), role (string: admin)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      // Temporary: Allow access if authenticated (including anonymous) or if in demo mode
      // Since we can't check demo mode in rules, we'll allow access for now to ensure data is recorded
      return true; 
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidString(field, min, max) {
      return request.resource.data[field] is string && 
             request.resource.data[field].size() >= min && 
             request.resource.data[field].size() <= max;
    }

    function isValidNumber(field, min) {
      return request.resource.data[field] is number && request.resource.data[field] >= min;
    }

    function isValidDate(field) {
      return request.resource.data[field] is string && request.resource.data[field].matches("^\\d{4}-\\d{2}-\\d{2}$");
    }

    // Collection Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /staff/{staffId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && 
                      hasRequiredFields(['name', 'role', 'monthlySalary', 'active']) &&
                      hasOnlyAllowedFields(['name', 'role', 'monthlySalary', 'active']) &&
                      isValidString('name', 1, 100) &&
                      isValidString('role', 1, 100) &&
                      isValidNumber('monthlySalary', 0);
      allow update: if isAdmin() && 
                      hasOnlyAllowedFields(['name', 'role', 'monthlySalary', 'active']) &&
                      isValidString('name', 1, 100) &&
                      isValidString('role', 1, 100) &&
                      isValidNumber('monthlySalary', 0);
      allow delete: if isAdmin();
    }

    match /attendance/{attendanceId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && 
                      hasRequiredFields(['date', 'staffId', 'status']) &&
                      hasOnlyAllowedFields(['date', 'staffId', 'status']) &&
                      isValidDate('date') &&
                      request.resource.data.status in ['present', 'absent', 'half-day', 'holiday'];
      allow update: if isAdmin() && 
                      hasOnlyAllowedFields(['date', 'staffId', 'status']) &&
                      isValidDate('date') &&
                      request.resource.data.status in ['present', 'absent', 'half-day', 'holiday'];
      allow delete: if isAdmin();
    }

    match /sales/{saleId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && 
                      hasRequiredFields(['date', 'customerName', 'product', 'quantity', 'amount', 'paymentStatus']) &&
                      hasOnlyAllowedFields(['date', 'salesmanId', 'customerName', 'product', 'quantity', 'amount', 'paymentStatus']) &&
                      isValidDate('date') &&
                      isValidString('customerName', 1, 200) &&
                      isValidString('product', 1, 100) &&
                      isValidNumber('quantity', 0) &&
                      isValidNumber('amount', 0) &&
                      request.resource.data.paymentStatus in ['paid', 'pending'];
      allow update: if isAdmin() && 
                      hasOnlyAllowedFields(['date', 'salesmanId', 'customerName', 'product', 'quantity', 'amount', 'paymentStatus']) &&
                      isValidDate('date') &&
                      isValidString('customerName', 1, 200) &&
                      isValidString('product', 1, 100) &&
                      isValidNumber('quantity', 0) &&
                      isValidNumber('amount', 0) &&
                      request.resource.data.paymentStatus in ['paid', 'pending'];
      allow delete: if isAdmin();
    }

    match /expenses/{expenseId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && 
                      hasRequiredFields(['date', 'type', 'amount', 'description']) &&
                      hasOnlyAllowedFields(['date', 'type', 'amount', 'staffId', 'description']) &&
                      isValidDate('date') &&
                      request.resource.data.type in ['advance', 'transport', 'other'] &&
                      isValidNumber('amount', 0) &&
                      isValidString('description', 1, 500);
      allow update: if isAdmin() && 
                      hasOnlyAllowedFields(['date', 'type', 'amount', 'staffId', 'description']) &&
                      isValidDate('date') &&
                      request.resource.data.type in ['advance', 'transport', 'other'] &&
                      isValidNumber('amount', 0) &&
                      isValidString('description', 1, 500);
      allow delete: if isAdmin();
    }
  }
}
